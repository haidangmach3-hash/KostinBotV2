# =====================================================
# 🤖 KOSTIN BOT V2 - CONFIGURATION
# =====================================================
#
# Hướng dẫn cấu hình:
# 1. Copy file này thành .env
# 2. Điền thông tin bên dưới
# 3. KHÔNG share file .env lên GitHub!
#
# =====================================================

# -------------------- DISCORD --------------------
# Bot Token từ Discord Developer Portal
# Cách lấy: https://discord.com/developers/applications
# → Chọn Bot → Reset Token / Regenerate
DISCORD_TOKEN=your_bot_token_here


# -------------------- APPLICATION --------------------
# Application ID / Client ID
# Cách lấy: Applications → General Information
CLIENT_ID=your_client_id_here

# Server ID để test commands (guild-specific)
# Cách lấy: Bật Developer Mode → Click chuột phải vào server → Copy ID
GUILD_ID=your_guild_id_here


# -------------------- DATABASE --------------------
# MongoDB Connection String
# Cách lấy: MongoDB Atlas → Connect → Connect your application
# Ví dụ: mongodb+srv://user:password@cluster.x.mongodb.net/?retryWrites=true&w=majority
MONGODB_URL=your_mongodb_connection_string

# Banner URL cho help menu (để trống nếu không dùng)
BANNER_URL= #không dùng thì để trống

# -------------------- BOT SETTINGS --------------------
# Prefix cho legacy commands (nếu dùng) - KHÔNG BẮT BUỘC
# PREFIX=!

# Bot Status - KHÔNG BẮT BUỘC
# Các loại: playing, watching, listening, competing
# BOT_STATUS=playing
# BOT_ACTIVITY=with Discord.js


# =====================================================
# 📝 NOTE: Xóa các dòng có chú thích "KHÔNG BẮT BUỘC"
#    nếu không sử dụng các tính năng đó.
# =====================================================
